
# ==================================================
# x86_64 Dependencies Base
# ==================================================
FROM ubuntu:22.04 AS smip-deps

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
  locales \
  && locale-gen en_US en_US.UTF-8 \
  && update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8 \
  && rm -rf /var/lib/apt/lists/*

ENV LANG=en_US.UTF-8
ENV LC_ALL=en_US.UTF-8

RUN apt-get update && apt-get install -y \
  software-properties-common curl \
  && add-apt-repository universe \
  && curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
     -o /usr/share/keyrings/ros-archive-keyring.gpg \
  && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] \
     http://packages.ros.org/ros2/ubuntu $(. /etc/os-release && echo $UBUNTU_CODENAME) main" \
     | tee /etc/apt/sources.list.d/ros2.list \
  && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install -y \
  ros-humble-ros-base \
  ros-humble-rmw-fastrtps-cpp \
  ros-humble-rmw-cyclonedds-cpp \
  ros-humble-launch-testing \
  ros-humble-ament-cmake \
  && rm -rf /var/lib/apt/lists/*

RUN apt-get update && apt-get install --no-install-recommends -y \
  build-essential \
  cmake \
  git \
  iproute2 \
  pkg-config \
  python3-pip \
  python3-colcon-common-extensions \
  python3-rosdep \
  python3-vcstool \
  && rm -rf /var/lib/apt/lists/*

RUN rosdep init || true && rosdep update --rosdistro humble

# Build px4_msgs natively — no cross-compilation concerns on x86
RUN mkdir -p /opt/px4_ws/src \
  && git clone --depth 1 --branch release/1.14 \
       https://github.com/PX4/px4_msgs.git /opt/px4_ws/src/px4_msgs \
  && cd /opt/px4_ws \
  && . /opt/ros/humble/setup.sh \
  && colcon build --cmake-args -DCMAKE_BUILD_TYPE=Release \
  && rm -rf build log src

RUN echo "source /opt/px4_ws/install/setup.bash" >> /etc/bash.bashrc

COPY dependencies/apt-deps.txt /tmp/apt-deps.txt
RUN apt-get update \
  && grep -vE '^\s*#|^\s*$' /tmp/apt-deps.txt | xargs -r apt-get install -y --no-install-recommends \
  && rm -rf /var/lib/apt/lists/*

COPY dependencies/pip-deps.txt /tmp/pip-deps.txt
RUN pip3 install --no-cache-dir -r /tmp/pip-deps.txt

RUN ldconfig


# ==================================================
# x86_64 Development Image
# ==================================================
FROM smip-deps AS smip-dev

RUN apt-get update && apt-get install -y --no-install-recommends \
  gdb \
  vim \
  ssh \
  sudo \
  && rm -rf /var/lib/apt/lists/*

ENV RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
